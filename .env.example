# ===========================================
#  Elena WordPress — Environment Variables
#  Copy to .env or set in Coolify dashboard
# ===========================================

# --- Database ---
DB_NAME=elena_wp
DB_USER=elena
DB_PASSWORD=CHANGE_ME_strong_password
DB_ROOT_PASSWORD=CHANGE_ME_root_password
TABLE_PREFIX=wp_

# --- Site URLs (include https://) ---
WP_HOME=https://your-domain.com
WP_SITEURL=https://your-domain.com

# --- WordPress Salts (generate at https://api.wordpress.org/secret-key/1.1/salt/) ---
AUTH_KEY=generate-me
SECURE_AUTH_KEY=generate-me
LOGGED_IN_KEY=generate-me
NONCE_KEY=generate-me
AUTH_SALT=generate-me
SECURE_AUTH_SALT=generate-me
LOGGED_IN_SALT=generate-me
NONCE_SALT=generate-me

# --- Debugging (set to 1 to enable) ---
WP_DEBUG=0
WP_DEBUG_LOG=0
